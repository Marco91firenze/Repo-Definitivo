{
  "name": "cval-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.cval.app",
    "productName": "CVAL Client",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "cval-client-setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Marco91firenze",
        "repo": "Repo-Definitivo"
      }
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.4.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  }
}
