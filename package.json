{
  "name": "cvai-client",
  "version": "1.0.0",
  "description": "CV AI Desktop Client",
  "main": "electron/main.js",
  "author": "Marco",
  "license": "MIT",
  "private": true,

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:win": "npm run build && npm run build:electron && electron-builder --win nsis"
  },

  "dependencies": {
    "electron-log": "^5.1.4"
  },

  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  },

  "build": {
    "appId": "com.cvai.desktop",
    "productName": "CVAI Scanner",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
