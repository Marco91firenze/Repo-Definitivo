{
  "name": "cv-fit-check",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.js",
  "author": "Marco91firenze",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.cvfit.check",
    "productName": "CV Fit Check",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "CV Fit Check Setup 1.0.0.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Marco91firenze",
      "repo": "Repo-Definitivo"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^29.4.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}
