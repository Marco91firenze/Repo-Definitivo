{
  "name": "cv-fit-check",
  "version": "1.0.0",
  "main": "main.js",
  "author": "Marco91firenze",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.cvfit.check",
    "productName": "CV Fit Check",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": "nsis",
      "artifactName": "CV Fit Check Setup 1.0.0.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "Marco91firenze",
      "repo": "Repo-Definitivo"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.4.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  }
}
